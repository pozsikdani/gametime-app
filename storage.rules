rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos
    match /profilePhotos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // License cards
    match /licenseCards/{teamId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
